# Copy thành client/.env
# Site key + server TURNSTILE_SECRETKEY phải cùng một widget trong Cloudflare Turnstile.
# Hostnames (bắt buộc khớp URL trình duyệt):
# - Mở http://localhost:5173  → phải có hostname "localhost" trong Turnstile (chỉ có 127.0.0.1 sẽ POST 400).
# - Hoặc luôn mở http://127.0.0.1:5173 nếu chỉ whitelist 127.0.0.1.
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Chỉ dev: bỏ qua Turnstile (đặt hàng không cần captcha) — đồng thời thêm TURNSTILE_SKIP=1 trong server/.env
# VITE_SKIP_TURNSTILE=true
