<script defer src="/js/imagePicker.module.js"></script>
<script defer src="/js/pageconfig.js"></script>
<form id="configForm">
  <div class="space-y-4">
<!-- =========== action =========== -->
<div class="flex justify-between items-center">
  <h2 class="text-lg font-bold">Pageconfig/ Cấu hình page</h2>
  <button
    type="submit"
    class="px-3 py-2 border border-gray-300 rounded-lg bg-blue-500 font-bold text-white"
  >
    Save Config
  </button>
</div>
<!-- ============ Hero ============= -->
<section class="border border-gray-300 rounded-lg">
  <button
    type="button"
    onclick="toggleSection('hero')"
    class="w-full flex justify-between p-3 font-medium"
  >
    Trang Hero/ Hero Section
    <span>+</span>
  </button>
  <!-- content -->
  <div class="p-4" id="hero">
    <input
      name="hero_badge"
      value="<%= pc?.hero?.badge || '' %>"
      placeholder="Badge"
      class="border w-full px-3 py-2 rounded"
    />

    <input
      name="hero_title"
      value="<%=pc?.hero?.title||''%>"
      placeholder="Title"
      class="border w-full px-3 py-2 rounded"
    />

    <textarea
      name="hero_desc"
      placeholder="Description"
      class="border w-full px-3 py-2 rounded"
    ><%=pc?.hero?.desc ||''%></textarea>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-2">
      <select name="hero_media_type" class="border w-full px-3 py-2 rounded">
        <option value="image" <%= (pc?.hero?.media_type || "image") === "image" ? "selected" : "" %>>Image</option>
        <option value="gif" <%= (pc?.hero?.media_type || "image") === "gif" ? "selected" : "" %>>GIF</option>
        <option value="video" <%= (pc?.hero?.media_type || "image") === "video" ? "selected" : "" %>>Video</option>
      </select>
      <input
        type="text"
        name="hero_media_url"
        value="<%=pc?.hero?.media_url||''%>"
        class="w-full px-4 py-3 border border-gray-300 rounded-lg hidden"
        placeholder="hero media path"
      />
    </div>

    <!-- <input
      name="hero_img_url"
      value="<%#=pc?.hero?.img_url||''%>"
      placeholder="Image URL"
      class="border w-full px-3 py-2 rounded"
    /> -->
    <!--  -->
    <!-- image handle action -->
<div class="image_action hero_media_action">
  <!-- <label for="">Image banner</label> -->
  <div class="flex gap-2 items-center mt-3">
    <button
      type="button"
      class="flex-1 px-4 py-3 chooseHeroImage rounded-lg border border-green-500"
    >
      Chọn ảnh/GIF
    </button>
    <button
      type="button"
      class="flex-1 px-4 py-3 chooseHeroVideo rounded-lg border border-blue-500"
    >
      Chọn video
    </button>
    <input
      type="text"
      name="hero_img_url"
      value="<%=pc?.hero?.img_url||''%>"
      class="flex-3 img_input w-full px-4 py-3 border border-gray-300 rounded-lg hidden"
      placeholder="img"
    />
  </div>
  <div class="img_preview border border-gray-300 w-full h-[200px] flex items-center justify-center overflow-hidden">
    <%
      const heroType = pc?.hero?.media_type || "image";
      const heroMedia = pc?.hero?.media_url || pc?.hero?.img_url || "";
    %>
    <% if (heroType === "video" && heroMedia) { %>
      <video src="/<%=heroMedia%>" class="w-full h-full object-cover" controls muted playsinline></video>
    <% } else { %>
      <img
        src="/<%=heroMedia%>"
        alt=""
        class="w-full object-cover max-h-[200px]"
      />
    <% } %>
  </div>
</div>
    <!--  -->
    <textarea name="hero_benefits" id="hero_benefits"  class=" w-full px-3 py-2 border border-gray-300 rounded-lg" placeholder="Enter = 1 sentence"><%=pc?.hero?.benefits.join("\n")%></textarea>

  </div>
</section>
<!-- PurchaseFrame -->
<section class="border border-gray-300 rounded-lg">
  <button
    type="button"
    onclick="toggleSection('purchase')"
    class="w-full flex justify-between p-3 font-medium"
  >
    Mua Ngay/ Purchase Section
    <span>+</span>
  </button>
  <!-- purchase -->
  <div class="p-4" id="purchase">
    <input
      name="purchase_title"
      value="<%=pc?.purchase_frame?.title||''%>"
      placeholder="Title"
      class="border w-full px-3 py-2 rounded"
    />
    <input
      name="purchase_countdown"
      type="datetime-local"
      value="<%=pc?.purchase_frame?.countdown ?  new Date(pc.purchase_frame.countdown).toISOString().slice(0,16) 
: ''%>"
      placeholder="Countdown"
      class="border w-full px-3 py-2 rounded"
    />
    <!-- issues list -->
    <!-- <textarea name="purchase_issues" id="" class="border w-full px-3 py-2 rounded" placeholder="Xuong dong = 1 record"><%= pc?.issue?.issues?.join('\n') || '' %></textarea> -->
     <h4 class="font-semibold pt-3">Floating CTA</h4>

    <input
      name="purchase_floating_cta"
      value="<%=pc?.purchase_frame?.floating_cta||''%>"
      placeholder="pre sale"
      class="border w-full px-3 py-2 rounded"
    />
    <!--  -->
    <h4 class="font-semibold pt-3">Purchase Card</h4>

    <input
      name="purchase_sale_presale"
      value="<%=pc?.purchase_frame?.sale?.presale||''%>"
      placeholder="pre sale"
      class="border w-full px-3 py-2 rounded"
    />
    <input
      name="purchase_sale_save_money"
      value="<%=pc?.purchase_frame?.sale?.save_money||''%>"
      placeholder="save money"
      class="border w-full px-3 py-2 rounded"
    /><input
      name="purchase_sale_price"
      value="<%=pc?.purchase_frame?.sale?.price||''%>"
      placeholder="Price"
      class="border w-full px-3 py-2 rounded"
    />
    <input
      name="purchase_sale_note"
      value="<%=pc?.purchase_frame?.sale?.note||''%>"
      placeholder="Card Title"
      class="border w-full px-3 py-2 rounded"
    />

    <!--  -->
      <h5 class="font-bold">Image <small>(1000x400)</small></h5>
    <!-- image handle action -->
<div class="image_action">
  <!-- <label for="">Image banner</label> -->
  <div class="flex justify-between items-center mt-3">
    <button
    type="button"
      class="flex-1 px-4 py-3 chooseImg rounded-lg border border-green-500"
    >
      Chọn ảnh
    </button>
    <input
      type="text"
      name="purchase_img_url"
      value="<%=pc?.purchase_frame?.img_url||''%>"
      class="flex-3 img_input w-full px-4 py-3 border border-gray-300 rounded-lg hidden"
      placeholder="img"
    />
  </div>
  <div class="img_preview border border-gray-300 w-full h-[200px]">
    <img
      src="/<%=pc?.purchase_frame?.img_url||''%>"
      alt=""
      class="w-full object-cover max-h-[200px]"
    />
  </div>
</div>
    <!--  -->
    <div class="flex justify-between items-center pt-3">
      <h5 class="font-bold">Policy (Icon + Text)</h5>
      <button
        type="button"
        id="cta_add_purchase_policy"
        class="px-3 py-2 border border-gray-300 rounded-lg bg-green-500 text-white font-bold"
      >
        + Add policy
      </button>
    </div>
    <div id="purchase_policy_wrapper" class="grid grid-cols-1 gap-2 mt-2">
      <% (pc?.purchase_frame?.policy || []).forEach(function(p){ 
        const icon = typeof p === "string" ? "Truck" : (p?.icon || "Truck");
        const text = typeof p === "string" ? p : (p?.text || "");
      %>
        <div class="instance border border-gray-300 rounded p-2">
          <div class="flex justify-end mb-2">
            <button type="button" class="remove-instance text-red-500 text-sm">Remove</button>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
            <input
              type="text"
              _icon
              value="<%=icon%>"
              class="px-3 py-2 border border-gray-300 rounded-lg"
              placeholder="Icon name (vd: Truck, ShieldCheck, RotateCcw)"
            />
            <input
              type="text"
              _text
              value="<%=text%>"
              class="px-3 py-2 border border-gray-300 rounded-lg"
              placeholder="Policy text"
            />
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<!-- =============== Warranty ============== -->   
<section class="border border-gray-300 rounded-lg">
    <button
      type="button"
      onclick="toggleSection('warranty')"
      class="w-full flex justify-between p-3 font-medium"
    >
      Quyền Lợi Bảo Hành/ Warranty Section
      <span>+</span>
    </button>
    <!-- Content -->
    <div class="p-4" id="warranty">
      <textarea
        id="warrantys"
        placeholder="enter = 1 sentence"
        class="border w-full px-3 py-2 rounded"
      ><%=pc?.warrantys?.join("\n")%></textarea>
    </div>
</section>
<!-- Target Audience -->
<section class="border border-gray-300 rounded-lg">
<button
  type="button"
  onclick="toggleSection('target_audience')"
  class="w-full flex justify-between p-3 font-medium"
>
  Đối Tượng Khách Hàng/ Target Audience
  <span>+</span>
</button>

<div class="p-4" id="target_audience">

  <input
    name="target_audience_title"
    value="<%= pc?.target_audience?.title || '' %>"
    placeholder="Section title"
    class="border w-full px-3 py-2 rounded"
  />

  <div class="flex justify-between items-center">

    <h4 class="font-semibold mt-4">Cards</h4>
    <button
    type="button"
    id="cta_add_target_card"
    class="mt-4 px-4 py-2 bg-blue-500 text-white rounded"
    >
    + Add Card
  </button>
</div>

  <div id="target_audience_wrapper" class="grid grid-cols-1 md:grid-cols-2 gap-4">

    <% pc?.target_audience?.cards?.forEach(function(card){ %>

    <div class="instance border p-4 rounded mt-3">

      <button
        type="button"
        class="remove-instance text-red-500 mb-2"
      >
        Remove
      </button>

      <!-- image -->
      <div class="image_action">

        <button
          type="button"
          class="chooseImg border px-4 py-2 rounded"
        >
          Chọn ảnh
        </button>
        <input
        name="img_url"
        value="<%= card?.img_url || '' %>"
        class="img_input hidden"
      />

        <div class="img_preview border mt-2 h-[150px]">
          <img
            src="/<%= card?.img_url || '' %>"
            class="w-full h-full object-cover"
          />
        </div>

      </div>

      <input
        name="title"
        value="<%= card?.title || '' %>"
        placeholder="Card title"
        class="border w-full px-3 py-2 rounded mt-2"
      />

      <textarea
        name="desc"
        placeholder="Description"
        class="border w-full px-3 py-2 rounded mt-2"
      ><%= card?.desc || '' %></textarea>

    </div>

    <% }) %>

  </div>

  

</div>
</section>
<!-- END -->
<!-- =============== Review ============== --> 
<section class="border border-gray-300 rounded-lg">
  <button
    type="button"
    onclick="toggleSection('review')"
    class="w-full flex justify-between p-3 font-medium"
  >
    Đánh Giá/ Review Section
    <span>+</span>
  </button>
  <!-- Content -->
  <div class="p-4" id="review">
    <input type="text" value="<%=pc?.review?.title%>" name="review_title" class="px-3 py-2 w-full border border-gray-300 rounded-lg" placeholder="video title">
    <div class="flex justify-between items-center py-2" >
      <h4 class="font-bold">video <small class="text-red-500" >Link(youtube:[watch|short])</small></h4>
      <button type="button" id="cta_add_review_card" class="px-3 py-2 border border-gray-300 rounded-lg bg-green-500 text-white font-bold">Add video component</button>
    </div>
    <div id="review_wapper" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <%if(pc?.review?.videos && pc?.review?.videos.length>0){%>
        <%pc.review.videos.forEach(v=>{%>
          <div class="instance relative">
            <span class="remove-instance w-5 h-5 rounded-lg bg-red-500 text-white font-bold hover:cursor-pointer hover:scale-120 flex items-center justify-center absolute -top-2 right-1">X</span>
            <div class="p-3 border border-gray-300">
              <input badge="" value="<%=v.badge%>" type="text" class="px-3 py-2 rounded-lg border border-gray-300 w-full" placeholder="lable">
              <input lable="" value="<%=v.lable%>" type="text" class="px-3 py-3 rounded-lg border border-gray-300 w-full" placeholder="lable">
              <textarea video="" name="" id="" class="px-3 py-2 border border-gray-300 w-full" placeholder="video_url"><%=v.video_url%></textarea>
            </div>
          </div>
        <%})%>
      <%}%>
    </div>
</section>
<!-- END -->
<!-- =============== Feedback ============== --> 
<section class="border border-gray-300 rounded-lg">
  <button
    type="button"
    onclick="toggleSection('feedback')"
    class="w-full flex justify-between p-3 font-medium"
  >
    Đánh Giá/ Feedback Section
    <span>+</span>
  </button>
  <!-- Content -->
  <div class="p-4" id="feedback">
    <input type="text" value="<%=pc?.feedback?.title%>" name="feedback_title" class="px-3 py-2 w-full border border-gray-300 rounded-lg" placeholder="video title">
    <div class="flex justify-between items-center py-2" >
      <h4 class="font-bold">feedback</h4>
      <button type="button" id="cta_add_feedback_card" class="px-3 py-2 border border-gray-300 rounded-lg bg-green-500 text-white font-bold">Add video component</button>
    </div>
    <div id="feedback_wapper" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <%if(pc?.feedback?.list && pc?.feedback?.list.length>0){%>
        <%pc.feedback.list.forEach(f=>{%>
          <div class="instance relative border border-gray-300 p-2">
            <span class="remove-instance w-5 h-5 rounded-lg bg-red-500 text-white font-bold hover:cursor-pointer hover:scale-120 flex items-center justify-center absolute -top-2 right-1">X</span>
            <div>
              <div class="flex">
                <input lable="" value="<%=f.title%>" type="text" class="px-3 py-2 rounded-lg border border-gray-300  w-full" placeholder="title">
                <input star="" value="<%=f.star%>" type="number" class="px-3 py-2 rounded-lg border border-gray-300  w-full" placeholder="star">
              </div>
              <textarea desc="" name="" id="" class="px-3 py-2 rounded-lg border border-gray-300 w-full" placeholder="comment"><%=f.desc%></textarea>
              <!-- <input type="text" class="px-3 py-2 rounded-lg border border-gray-300  w-full" placeholder="title"> -->
            </div>
          </div>
        <%})%>
      <%}%>
    </div>
</section>
<!-- =============== Teachnology ============ -->
 <section class="border border-gray-300 rounded-lg">
  <button
    type="button"
    onclick="toggleSection('teachnology')"
    class="w-full flex justify-between p-3 font-medium"
  >
    Kỹ Thuật/ Teachnology Section
    <span>+</span>
  </button>
  <!-- Content -->
  <div class="p-4" id="teachnology">
    <input type="text" value="<%=pc?.teachnology?.title%>" name="teachnology_title" class="px-3 py-2 w-full border border-gray-300 rounded-lg" placeholder="teachnology title">
    <input type="text" value="<%=pc?.teachnology?.desc%>" name="teachnology_desc" class="px-3 py-2 w-full border border-gray-300 rounded-lg" placeholder="teachnology desc">
    <div class="flex justify-between items-center py-2" >
      <h4 class="font-bold">Teachnology</h4>
      <button type="button" id="cta_add_teachnology_card" class="px-3 py-2 border border-gray-300 rounded-lg bg-green-500 text-white font-bold">Add video component</button>
    </div>
    <div id="teachnology_wrapper" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <%if(pc?.teachnology?.cards && pc?.teachnology?.cards.length>0){%>
        <%pc.teachnology.cards.forEach(t=>{%>
          <div class="instance relative">
            <span class="remove-instance w-5 h-5 rounded-lg bg-red-500 text-white font-bold hover:cursor-pointer hover:scale-120 flex items-center justify-center absolute -top-2 right-1">X</span>
            
              <div class="p-2 border border-gray-300">
                
                <input value="<%=t.badge%>" type="text" _badge class="px-3 py-2 border border-gray-300 rounded-lg w-full" placeholder="badge">
              <!-- image handle action -->
            <div class="image_action">
              <!-- <label for="">Image banner</label> -->
              <div class="flex justify-between items-center mt-3">
                <button
                  type="button"
                  class="flex-1 px-4 py-3 chooseImg rounded-lg border border-green-500"
                >
                  Chọn ảnh
                </button>
                <input
                  type="text"
                  value="<%=t.img_url%>"
                  _img_url=""
                  class=" flex-3 img_input w-full px-4 py-3 border border-gray-300 rounded-lg hidden"
                  placeholder="img"
                />
              </div>
              <div class="img_preview border border-gray-300 w-full h-[200px]">
                <img
                  src="/<%=t.img_url%>"
                  class="w-full object-cover max-h-[200px]"
                />
              </div>
            </div>
            <!--  -->
            <input type="text" value="<%=t.title%>" _label="" class="px-3 py-2 border border-gray-300 w-full rounded-lg" placeholder="title">
            <textarea name="" _desc="" id="" class="px-3 py-2 border border-gray-300 w-full rounded-lg" placeholder="description"><%=t.desc%></textarea>
              

            </div>
          </div>
        <%})%>
      <%}%>
    </div>
</section>
<!-- =============== Featured ============ -->
 <section class="border border-gray-300 rounded-lg">
  <button
    type="button"
    onclick="toggleSection('featured')"
    class="w-full flex justify-between p-3 font-medium"
  >
    Tính Năng Đặc Biệt/Featured Section
    <span>+</span>
  </button>
  <!-- Content -->
  <div class="p-4" id="featured">
    <input type="text" value="<%=pc?.is_featured?.title%>" name="featured_title" class="px-3 py-2 w-full border border-gray-300 rounded-lg" placeholder="featured title">
    <div class="flex justify-between items-center py-2" >
      <h4 class="font-bold">featured</h4>
      <button type="button" id="cta_add_featured_card" class="px-3 py-2 border border-gray-300 rounded-lg bg-green-500 text-white font-bold">Add video component</button>
    </div>
    <div id="featured_wrapper" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <%if(pc?.is_featured?.cards && pc?.is_featured?.cards.length>0){%>
        <%pc.is_featured.cards.forEach(f=>{%>
          <div class="instance relative">
            <span class=" remove-instance w-5 h-5 bg-red-500 rounded-full hover:scale-120 hover:cursor-pointer text-white font-bold absolute -top-2 right-1">X</span>
            <div class="border border-gray-300 p-2">
              <!-- image handle action -->
              <div class="image_action">
                <!-- <label for="">Image banner</label> -->
                <div class="flex justify-between items-center mt-3">
                  <button
                    type="button"
                    class="flex-1 px-4 py-3 chooseImg rounded-lg border border-green-500"
                  >
                    Chọn ảnh
                  </button>
                  <input
                    type="text"
                    _img_url
                    value="<%=f.img_url%>"
                    class=" flex-3 img_input w-full px-4 py-3 border border-gray-300 rounded-lg hidden"
                    placeholder="img"
                  />
                </div>
                <div class="img_preview border border-gray-300 w-full h-[200px]">
                  <img
                    src="/<%=f.img_url%>"
                    class="w-full object-cover max-h-[200px]"
                  />
                </div>
              </div>
              <input type="text" value="<%=f.title%>" _label class="px-3 py-2 border border-gray-300 rounded-lg w-full "placeholder="title">
              <input type="text" value="<%=f.desc%>" _desc class="px-3 py-2 border border-gray-300 rounded-lg w-full "placeholder="desc">
            </div>
          </div>
        <%})%>
      <%}%>
    </div>
</section>
<!-- =============== Box_content ============ -->
 <section class="border border-gray-300 rounded-lg">
  <button
    type="button"
    onclick="toggleSection('box_content')"
    class="w-full flex justify-between p-3 font-medium"
  >
    Nội Dung Box/ Box_content Section
    <span>+</span>
  </button>
  <!-- Content -->
  <div class="p-4" id="box_content">
    <input type="text" value="<%=pc?.box_content?.title%>" name="box_content_title" class="px-3 py-2 w-full border border-gray-300 rounded-lg" placeholder="box_content title">
    <!-- image handle action -->
    <div class="image_action">
      <!-- <label for="">Image banner</label> -->
      <div class="flex justify-between items-center mt-3">
        <button
          type="button"
          class="flex-1 px-4 py-3 chooseImg rounded-lg border border-green-500"
        >
          Chọn ảnh
        </button>
        <input
          type="text"
          value="<%=pc?.box_content?.img_url%>"
          name="box_content_img_url"
          class=" flex-3 img_input w-full px-4 py-3 border border-gray-300 rounded-lg hidden"
          placeholder="img"
        />
      </div>
      <div class="img_preview border border-gray-300 w-full h-[200px]">
        <img
          src="/<%=pc?.box_content?.img_url%>"
          alt=""
          class="w-full object-cover max-h-[200px]"
        />
      </div>
    </div>
    <textarea name="" id="box_content_list" class="px-3 py-2 border border-gray-300 rounded-lg w-full" placeholder="enter = 1 sentence"><%=pc?.box_content?.list.join("\n")%></textarea>
</section>
<!-- =============== Usage_instruction ============ -->
 <section class="border border-gray-300 rounded-lg">
  <button
    type="button"
    onclick="toggleSection('usage_instruction')"
    class="w-full flex justify-between p-3 font-medium"
  >
    Hướng Dẫn Sử Dụng/ Usage Instruction Section
    <span>+</span>
  </button>
  <!-- Content -->
  <div class="p-4" id="usage_instruction">
    <input type="text" value="<%=pc?.usage_instruction?.title%>" name="usage_instruction_title" class="px-3 py-2 w-full border border-gray-300 rounded-lg" placeholder="box_content title">
    <input type="text" value="<%=pc?.usage_instruction?.note%>" name="usage_instruction_note" class="px-3 py-2 w-full border border-gray-300 rounded-lg" placeholder="box_content note">
    <div class="flex justify-between items-center py-2" >
      <h4 class="font-bold">usage_instruction</h4>
      <button type="button" id="cta_add_usage_instruction_card" class="px-3 py-2 border border-gray-300 rounded-lg bg-green-500 text-white font-bold">Add video component</button>
    </div>
    <div id="usage_instruction_wrapper" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <%if(pc?.usage_instruction?.cards && pc?.usage_instruction?.cards.length> 0){%>
        <%pc?.usage_instruction?.cards.forEach(i=>{%>
          <div class="instance relative">
            <span class=" remove-instance w-5 h-5 bg-red-500 rounded-full hover:scale-120 hover:cursor-pointer text-white font-bold absolute -top-2 right-1">X</span>
            <div class="border border-gray-300 p-2">
            <!-- image handle action -->
            <div class="image_action">
              <!-- <label for="">Image banner</label> -->
              <div class="flex justify-between items-center mt-3">
                <button
                  type="button"
                  class="flex-1 px-4 py-3 chooseImg rounded-lg border border-green-500"
                >
                  Chọn ảnh
                </button>
                <input
                  type="text"
