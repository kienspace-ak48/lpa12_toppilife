<!-- //===================== -->
 <script>
  // ================ body area ============== //
  const bodyAreaTemplate = document.querySelector('#body_area_template');
  const bodyAreaWrapper = document.querySelector('#body_area_wrapper');
  document.querySelector('#cta_add_body_area_card').addEventListener('click', (ev)=>{
    const clone = bodyAreaTemplate.content.cloneNode(true);
    bodyAreaWrapper.appendChild(clone);
  });
  bodyAreaWrapper.addEventListener('click', (ev)=>{
    if(ev.target.classList.contains('remove-instance')){
      const instance = ev.target.closest('.instance');
      instance.remove();
    }
  })
  // ================ usage_instruction =======//
  const usageInstructionWrapper = document.querySelector('#usage_instruction_wrapper');
  const usageInstructionTemplate = document.querySelector('#usage_instruction_template');

  document.querySelector('#cta_add_usage_instruction_card').addEventListener('click', (ev)=>{
    const clone = usageInstructionTemplate.content.cloneNode(true);
    usageInstructionWrapper.appendChild(clone);
  })
  usageInstructionWrapper.addEventListener('click', (ev)=>{
    if(ev.target.classList.contains('remove-instance')){
      const instance = ev.target.closest('.instance');
      instance.remove();
    }
  })

  // ================= Featured ===============//
  const featuredWrapper =document.querySelector('#featured_wrapper');
  const featuredTemplate = document.querySelector('#featured_template');
  document.querySelector('#cta_add_featured_card').addEventListener('click', (ev)=>{
    const clone = featuredTemplate.content.cloneNode(true);
    featuredWrapper.appendChild(clone);
  });
  featuredWrapper.addEventListener('click', (ev)=>{
    if(ev.target.classList.contains('remove-instance')){
      const instance = ev.target.closest('.instance');
      instance.remove();
    }
  })
  // =================teachnology ==========//
  const teachnologyWrapper = document.querySelector('#teachnology_wrapper');
  const teachnologyTemplate = document.querySelector('#teachnolory_template');
  document.querySelector('#cta_add_teachnology_card').addEventListener('click', (ev)=>{
    const clone = teachnologyTemplate.content.cloneNode(true);
    teachnologyWrapper.appendChild(clone);
  });
  teachnologyWrapper.addEventListener('click', (ev)=>{
    if(ev.target.classList.contains('remove-instance')){
      const instance = ev.target.closest('.instance');
      instance.remove();
    }
  })
  // =============== review =============//
  const reviewWarpper = document.querySelector('#review_wapper');
  const reviewTemplate = document.querySelector('#review_template');
  document.querySelector('#cta_add_review_card').addEventListener('click', (ev)=>{
    // console.log('a')
    const clone = reviewTemplate.content.cloneNode(true);
    console.log(clone);
    reviewWarpper.appendChild(clone);
  });
  reviewWarpper.addEventListener('click', (ev)=>{
    if(ev.target.classList.contains("remove-instance")){
      const instance = ev.target.closest('.instance');
      instance.remove();
    }
  });
  // ================= FeedBack ==============//
  const feebdackWrapper = document.querySelector('#feedback_wapper');
  const feedbackTemplate = document.querySelector('#feedback_template');

  document.querySelector('#cta_add_feedback_card').addEventListener('click', (ev)=>{
    const clone = feedbackTemplate.content.cloneNode(true);
    feebdackWrapper.appendChild(clone);
  })
  feebdackWrapper.addEventListener('click', (ev)=>{
    if(ev.target.classList.contains("remove-instance")){
      const instance = ev.target.closest('.instance')
      instance.remove();
    }
  })
  // ================= Purchase Policy ==============//
  const purchasePolicyWrapper = document.querySelector('#purchase_policy_wrapper');
  const purchasePolicyTemplate = document.querySelector('#purchase_policy_template');
  const ctaAddPurchasePolicy = document.querySelector('#cta_add_purchase_policy');
  if (purchasePolicyWrapper && purchasePolicyTemplate && ctaAddPurchasePolicy) {
    ctaAddPurchasePolicy.addEventListener('click', ()=>{
      const clone = purchasePolicyTemplate.content.cloneNode(true);
      purchasePolicyWrapper.appendChild(clone);
    });
    purchasePolicyWrapper.addEventListener('click', (ev)=>{
      if(ev.target.classList.contains("remove-instance")){
        const instance = ev.target.closest('.instance');
        instance.remove();
      }
    });
  }

  

 </script>
 

