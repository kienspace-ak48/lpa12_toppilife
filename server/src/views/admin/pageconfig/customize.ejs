<script defer src="/js/admin-media-picker.js"></script>
<style>
  #pageinfo .image_action input.img_input {
    clip: rect(0, 0, 0, 0);
    clip-path: inset(50%);
    height: 1px;
    width: 1px;
    overflow: hidden;
    position: absolute;
    left: 0;
    bottom: 0;
    white-space: nowrap;
    padding: 0;
    margin: 0;
    border: 0;
  }
  #pageinfo .image_action {
    position: relative;
  }
</style>
<div class="flex justify-between items-center">
  <h2 class="font-bold">
    Customize section/ Tùy chỉnh cấu hình web
    <i
      class="text-blue-500 hover:cursor-pointer fa-regular fa-circle-question hover:scale-150"
    ></i>
  </h2>
  <button
    id="btn_cta_save_config"
    class="font-bold px-4 py-3 rounded-lg border border-gray-300 bg-blue-500 text-white"
  >
    Save config
  </button>
</div>
<!-- page info -->
<section id="pageinfo">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Email -->
    <div>
      <label class="form-label font-medium">Email</label>
      <input
        type="text"
        name="pageinfo_email"
        value="<%=data?.customize?.email||''%>"
        class="w-full border border-gray-300 rounded-lg px-3 py-2"
        placeholder="admin@gmail.com"
      />
    </div>

    <!-- Phone -->
    <div>
      <label class="form-label font-medium">Phone number</label>
      <input
        type="text"
        name="pageinfo_phone"
        value="<%=data?.customize?.phone||''%>"
        class="w-full border border-gray-300 rounded-lg px-3 py-2"
        placeholder="19001900"
      />
    </div>

    <!-- Zalo -->
    <div>
      <label class="form-label font-medium">Zalo</label>
      <input
        type="text"
        name="pageinfo_zalo"
        value="<%=data?.customize?.zalo||''%>"
        class="w-full border border-gray-300 rounded-lg px-3 py-2"
        placeholder="19001900"
      />
    </div>

    <!-- Address -->
    <div>
      <label class="form-label font-medium">Address</label>
      <input
        type="text"
        name="pageinfo_address"
        value="<%=data?.customize?.address||''%>"
        class="w-full border border-gray-300 rounded-lg px-3 py-2"
        placeholder="123 Đường ABC, Quận XYZ, TP.HCM"
      />
    </div>

    <!-- Facebook -->
    <div>
      <label class="form-label font-medium">Facebook</label>
      <input
        type="text"
        name="pageinfo_facebook"
        value="<%=data?.customize?.facebook||''%>"
        class="w-full border border-gray-300 rounded-lg px-3 py-2"
        placeholder="https://facebook.com/yourpage"
      />
    </div>

    <!-- TikTok -->
    <div>
      <label class="form-label font-medium">TikTok</label>
      <input
        type="text"
        name="pageinfo_tiktok"
        value="<%=data?.customize?.tiktok||''%>"
        class="w-full border border-gray-300 rounded-lg px-3 py-2"
        placeholder="https://tiktok.com/@yourpage"
      />
    </div>

    <!-- YouTube -->
    <div>
      <label class="form-label font-medium">YouTube</label>
      <input
        type="text"
        name="pageinfo_youtube"
        value="<%=data?.customize?.youtube||''%>"
        class="w-full border border-gray-300 rounded-lg px-3 py-2"
        placeholder="https://youtube.com/@yourchannel"
      />
    </div>

    <!-- Footer title -->
    <div>
      <label class="form-label font-medium">subtitle word footer  </label>
      <input
        type="text"
        name="worktime"
        value="<%=data?.customize?.worktime||''%>"
        class="w-full border border-gray-300 rounded-lg px-3 py-2"
        placeholder="Title..."
      />
    </div>
  </div>

  <hr class="my-6 border-gray-300" />
  <h4 class="font-bold pb-4 text-lg">[--- SEO ---]</h4>

  <!-- SEO Section -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <div class="py-2">
        <label class="font-medium">Website name</label>
        <input
          type="text"
          id="webname"
          value="<%=data?.customize?.title||''%>"
          class="w-full border border-gray-300 rounded-lg px-3 py-2"
        />
      </div>

      <div class="py-2">
        <label class="font-medium">Desc</label>
        <input
          type="text"
          id="desc"
          value="<%=data?.customize?.desc||''%>"
          class="w-full border border-gray-300 rounded-lg px-3 py-2"
        />
      </div>
      <div class="py-2">
        <label class="font-medium"> Canonical <small style="color: red">(thêm "/" ở cuối url)</small> </label>
        <input
          type="text"
          id="canonical"
          value="<%=data?.customize?.canonical ||''%>"
          class="w-full border border-gray-300 rounded-lg px-3 py-2"
        />
      </div>

      <div class="py-2">
        <label class="font-medium">Google Tag Manager (Container ID)</label>
        <input
          type="text"
          id="gtm_id"
          value="<%=data?.customize?.gtm_id || ''%>"
          class="w-full border border-gray-300 rounded-lg px-3 py-2"
          placeholder="GTM-XXXXXXX"
        />
        <small style="color:#6b7280;">Để trống nếu không dùng. Ví dụ: GTM-TR6N9NQ</small>
      </div>

      <div class="py-2">
        <label class="font-medium">Meta (Facebook) Pixel ID</label>
        <input
          type="text"
          id="fb_pixel_id"
          value="<%=data?.customize?.fb_pixel_id || ''%>"
          class="w-full border border-gray-300 rounded-lg px-3 py-2"
          placeholder="1291350602880286"
        />
        <small style="color:#6b7280;">Chỉ nhập ID pixel (số). Để trống nếu không dùng.</small>
      </div>
    </div>
    <!-- right -->
    <div>
      <div class="py-2">
        <label class="font-medium">Keyword</label>
        <input
          type="text"
          id="keywords"
          value="<%=data?.customize?.keywords||''%>"
          class="w-full border border-gray-300 rounded-lg px-3 py-2"
        />
      </div>

      <div class="py-2">
        <label class="font-medium">OpenGraph image</label>
        <div class="image_action mt-2 space-y-2">
          <button
            type="button"
            class="chooseImg px-4 py-2 rounded-lg border border-green-600 bg-green-50 text-sm font-semibold text-green-800 hover:bg-green-100"
          >
            Chọn media
          </button>
          <input
            type="text"
            name="website_img"
            value="<%=data?.customize?.img||''%>"
            class="img_input w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"
            placeholder="uploads/... (đường dẫn trong public)"
          />
          <div class="img_preview border border-gray-300 w-full h-[200px] flex items-center justify-center bg-gray-50 overflow-hidden">
            <img
              src="/<%=data?.customize?.img||''%>"
              alt=""
              class="w-full object-cover max-h-[200px]"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<script>
  document.getElementById("btn_cta_save_config").addEventListener("click", async () => {
    const data = {
      pageinfo_email: document.querySelector("[name='pageinfo_email']").value,
      pageinfo_phone: document.querySelector("[name='pageinfo_phone']").value,
      pageinfo_zalo: document.querySelector("[name='pageinfo_zalo']").value,
      pageinfo_address: document.querySelector("[name='pageinfo_address']").value,
      pageinfo_facebook: document.querySelector("[name='pageinfo_facebook']").value,
      pageinfo_tiktok: document.querySelector("[name='pageinfo_tiktok']").value,
      pageinfo_youtube: document.querySelector("[name='pageinfo_youtube']").value,
      worktime: document.querySelector("[name='worktime']").value,
      webname: document.getElementById("webname").value,
      canonical: document.getElementById("canonical").value,
      desc: document.getElementById("desc").value,
      keywords: document.getElementById("keywords").value,
      gtm_id: document.getElementById("gtm_id").value,
      fb_pixel_id: document.getElementById("fb_pixel_id").value,
      img: document.querySelector("[name='website_img']").value,
    };

    const res = await fetch("/admin/page-config/customize-section", {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(data),
    });
    const result = await res.json();
    if (result.success) alert("update successfully");
    else alert("update failed");
  });
</script>
